# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SCRAPE_CREATORS_API_KEY: Optional API key for scraping Meta Ads Library via scrapecreators.com
SCRAPE_CREATORS_API_KEY=""


# VITE_GOOGLE_SHEETS_API_URL: Google Apps Script Web App URL trả JSON 5 bảng
# từ Google Sheets (chế độ ONLINE SHEET DATA). Đặt biến này trên Vercel →
# Settings → Environment Variables rồi redeploy. KHÔNG commit URL thật.
# Đây KHÔNG phải secret/private key — chỉ là endpoint đọc dữ liệu dashboard.
VITE_GOOGLE_SHEETS_API_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec


# ============================================================
# AUTOMATED WEEKLY SPY PIPELINE (server-side / serverless only)
# Các biến dưới đây CHỈ đọc trong /api/* (Vercel Functions).
# TUYỆT ĐỐI không có prefix VITE_ → không lộ ra frontend bundle.
# Xem README_AUTOMATED_WEEKLY_SPY.md để biết cách lấy & cấu hình.
# ============================================================

# Google Sheet đích để GHI 5 tab output (Sheets API, service account).
GOOGLE_SHEET_ID=11WRRCa5AfIoWDK9qo3UqT3QvdrD0xCRY-zRd-8Ezj0Q

# Service account dùng để ghi vào Google Sheets.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Private key PEM của service account. Trên Vercel dán nguyên chuỗi
# "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# (\n literal được tự chuyển thành xuống dòng trong code).
GOOGLE_PRIVATE_KEY=

# Nguồn ads: mock | apify | custom  (mock = sample data để test, KHÔNG phải ads thật).
ADS_SOURCE_PROVIDER=mock
# API key cho provider apify/custom (để trống nếu dùng mock).
ADS_SOURCE_API_KEY=
# URL HTTP API khi ADS_SOURCE_PROVIDER=custom.
ADS_SOURCE_API_URL=
# (tùy chọn) Quốc gia lọc ads. Mặc định VN.
ADS_SOURCE_COUNTRY=VN

# Bí mật bảo vệ /api/run-weekly-spy. ĐỔI giá trị này trên Vercel.
CRON_SECRET=change-me


# ============================================================
# LOCAL SYNC SCRIPT — scripts/run-weekly-spy-and-sync.mjs
# Chạy `npm run spy:sync` trên máy local để ghi mock data lên Google Sheets.
# Dùng FILE service account JSON (KHÁC với EMAIL/PRIVATE_KEY ở trên dành cho serverless).
# KHÔNG commit .env / file JSON / secrets.
# (GOOGLE_SHEET_ID dùng chung biến ở trên)
# ============================================================
GOOGLE_SERVICE_ACCOUNT_FILE=C:/seryn-spy-agent/secrets/google-service-account.json
