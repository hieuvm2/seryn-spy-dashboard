# Template — copy thành .env rồi điền. KHÔNG commit .env / file JSON / secrets.

# ── SUPABASE (nguồn dashboard đọc + pipeline đẩy) ────────────
# Dashboard ĐỌC bằng anon key (PUBLIC, chỉ SELECT theo RLS). Đặt trên Vercel.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY
# Pipeline/Claude GHI bằng service_role key (SECRET — chỉ server/.env, KHÔNG commit,
# trên GitHub Actions đặt làm secret). Bypass RLS để upsert bảng spy_data.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
# (Chạy 1 lần: supabase/schema.sql trong Supabase SQL Editor để tạo bảng spy_data.)

# ── Dashboard ĐỌC online (fallback nếu không dùng Supabase) ──
# URL Apps Script Web App (doGet trả JSON 5 bảng). Đặt trên Vercel →
# Settings → Environment Variables → Redeploy. KHÔNG phải secret.
VITE_GOOGLE_SHEETS_API_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# ── Local sync GHI (npm run spy:sync) ────────────────────────
# Đọc 5 CSV trong outputs/ → ghi Google Sheets bằng service account.
GOOGLE_SHEET_ID=11WRRCa5AfIoWDK9qo3UqT3QvdrD0xCRY-zRd-8Ezj0Q
GOOGLE_SERVICE_ACCOUNT_FILE=C:/seryn-spy-agent/secrets/google-service-account.json
# (tùy chọn) thư mục output CSV của agent. Mặc định <web-react>/outputs.
# Nếu agent ghi outputs/ ở thư mục khác (vd repo cha), trỏ tường minh:
# OUTPUTS_DIR=C:/seryn-spy-agent/outputs
# Nhớ: Share Google Sheet (Editor) cho client_email trong file JSON.

# ── (Tùy chọn) Bảo vệ Apps Script Web App bằng API key ───────
# Dùng cho dashboard ĐỌC online khi Apps Script bật kiểm tra key.
# Phải khớp Script Property API_SECRET_KEY trong Apps Script.
# VITE_GOOGLE_SHEETS_API_KEY=your-secret-key

# ── Weekly automated spy sync (npm run spy:weekly / GitHub Actions) ──
# Pull ads -> phân tích -> ghi 5 tab Google Sheets. Dùng GOOGLE_SHEET_ID ở trên.
# Trên GitHub Actions: đặt GOOGLE_SERVICE_ACCOUNT_JSON = TOÀN BỘ nội dung file JSON.
# Khi chạy local: có thể bỏ trống JSON và dùng GOOGLE_SERVICE_ACCOUNT_FILE ở trên.
GOOGLE_SERVICE_ACCOUNT_JSON=
# Provider nguồn ads: mock (test) | scrapecreators (ads thật) | custom (API riêng)
ADS_SOURCE_PROVIDER=mock
# provider=scrapecreators: 1+ API key ScrapeCreators (phân cách bằng dấu phẩy → rotation).
# provider=custom: dùng ADS_SOURCE_API_URL bên dưới.
ADS_SOURCE_API_KEY=
ADS_SOURCE_API_URL=
# (tùy chọn, provider=scrapecreators) quốc gia + số ad tối đa mỗi page_id:
ADS_SOURCE_COUNTRY=VN
ADS_SOURCE_MAX_ADS=80
# Phạm vi spy: mặc định CHỈ ad trẻ hóa da (skin_rejuvenation). Đặt =all để tắt lọc (không khuyến nghị).
# ADS_SCOPE=skin_rejuvenation

# ── Incremental cache + visual heuristic ────────────────────
# Pipeline chỉ phân tích ad MỚI / ad có content_hash|visual_hash THAY ĐỔI;
# ad cũ không đổi -> reuse kết quả từ tab "Ad Analysis Cache".
VISUAL_AI_PROVIDER=heuristic          # hiện chỉ heuristic (rule-based)
TEXT_ANALYSIS_PROMPT_VERSION=t1       # đổi version -> buộc phân tích lại text
VISUAL_ANALYSIS_PROMPT_VERSION=v1     # đổi version -> buộc phân tích lại visual

# ── Exa Market Research & Competitor Discovery — MANUAL / ON-DEMAND ONLY ──
# Exa CHỈ chạy thủ công (GitHub Actions workflow_dispatch). KHÔNG gắn vào
# weekly spy cron. KHÔNG gọi từ frontend. KHÔNG dùng VITE_EXA_API_KEY.
# Chỉ script server-side đọc process.env.EXA_API_KEY (GitHub Secret).
EXA_API_KEY=
EXA_SEARCH_TYPE=auto
EXA_MAX_RESULTS_PER_QUERY=10
EXA_MAX_QUERIES_PER_RUN=10
EXA_ENABLE_DEEP_SEARCH=false
EXA_SEARCH_COUNTRY=VN

MARKET_RESEARCH_RUN_MODE=manual
MARKET_RESEARCH_GEO=Vietnam
# (market + service_category cố định skin_rejuvenation trong scripts/lib/runConfig.mjs)
MARKET_SIZE_ESTIMATION_MODE=directional

# Competitor discovery — auto import mặc định TẮT (review thủ công trước).
AUTO_IMPORT_COMPETITORS=false
COMPETITOR_AUTO_IMPORT_MIN_CONFIDENCE=0.80
COMPETITOR_DISCOVERY_MIN_CONFIDENCE=0.55
# Tự resolve Facebook page_id khi import đối thủ (ScrapeCreators search-by-name,
# cần ADS_SOURCE_API_KEY; KHÔNG bịa id — resolve không ra thì skip để review tay).
RESOLVE_PAGE_ID=true
MAX_PAGE_ID_RESOLVES_PER_RUN=20
